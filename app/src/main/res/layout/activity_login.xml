<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loginRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tvToggleModo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_toggle_registro"
            android:textColor="@color/color_acento"
            android:textSize="14sp"
            android:padding="8dp"
            android:layout_marginTop="44dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTituloLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_app"
            android:textColor="@color/color_acento"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="148dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtituloLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitulo_app"
            android:textColor="@color/color_texto_secundario"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/formularioLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtituloLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvModoLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_btn_ingresar"
                android:textColor="@color/color_texto_primario"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="28dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:hint="@string/login_hint_email"
                android:textColor="@color/color_texto_primario"
                android:textColorHint="@color/color_texto_secundario"
                android:inputType="textEmailAddress"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#80E2B96F"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/login_hint_password"
                    android:textColor="@color/color_texto_primario"
                    android:textColorHint="@color/color_texto_secundario"
                    android:inputType="textPassword"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:paddingBottom="8dp"
                    android:imeOptions="actionDone"
                    android:singleLine="true" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_eye"
                    android:background="@android:color/transparent"
                    android:padding="8dp"
                    android:contentDescription="Mostrar/ocultar contraseña" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#80E2B96F"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnAccion"
                android:layout_width="match_parent"
                android:layout_height="@dimen/alto_boton"
                android:text="@string/login_btn_ingresar"
                android:textColor="@color/color_fondo"
                android:backgroundTint="@color/color_acento"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/margen_grande" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EF5350"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="@dimen/margen_pequeño"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
