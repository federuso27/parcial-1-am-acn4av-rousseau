<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loginRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/margen_grande"
        android:paddingEnd="@dimen/margen_grande"
        android:paddingBottom="@dimen/margen_grande">

        <TextView
            android:id="@+id/tvTituloLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_app"
            android:textColor="@color/color_acento"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="72dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtituloLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitulo_app"
            android:textColor="@color/color_texto_secundario"
            android:textSize="@dimen/texto_cuerpo"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/formularioLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="56dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtituloLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/alto_boton"
                android:background="@drawable/fondo_input"
                android:hint="@string/login_hint_email"
                android:textColor="@color/color_texto_primario"
                android:textColorHint="@color/color_texto_secundario"
                android:inputType="textEmailAddress"
                android:paddingStart="@dimen/margen_medio"
                android:paddingEnd="@dimen/margen_medio"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/alto_boton"
                android:background="@drawable/fondo_input"
                android:hint="@string/login_hint_password"
                android:textColor="@color/color_texto_primario"
                android:textColorHint="@color/color_texto_secundario"
                android:inputType="textPassword"
                android:paddingStart="@dimen/margen_medio"
                android:paddingEnd="@dimen/margen_medio"
                android:layout_marginTop="@dimen/margen_medio"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnAccion"
                android:layout_width="match_parent"
                android:layout_height="@dimen/alto_boton"
                android:text="@string/login_btn_ingresar"
                android:textColor="@color/color_fondo"
                android:backgroundTint="@color/color_acento"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/margen_grande" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EF5350"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="@dimen/margen_pequeño"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvToggleModo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_toggle_registro"
                android:textColor="@color/color_acento"
                android:textSize="@dimen/texto_cuerpo"
                android:layout_marginTop="@dimen/margen_medio"
                android:layout_gravity="center"
                android:padding="@dimen/margen_pequeño" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
