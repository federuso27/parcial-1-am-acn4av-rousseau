<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/margen_medio"
        android:paddingEnd="@dimen/margen_medio"
        android:paddingTop="@dimen/margen_grande"
        android:paddingBottom="@dimen/margen_pequeño"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/portfolio_titulo"
            android:textColor="@color/color_acento"
            android:textSize="@dimen/texto_titulo"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitulo_app"
            android:textColor="@color/color_texto_secundario"
            android:textSize="@dimen/texto_cuerpo"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_borde"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <LinearLayout
        android:id="@+id/layoutValorTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/fondo_carta"
        android:padding="@dimen/margen_medio"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        android:layout_marginTop="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/portfolio_valor_total"
            android:textColor="@color/color_texto_secundario"
            android:textSize="@dimen/texto_cuerpo" />

        <TextView
            android:id="@+id/tvValorTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ 0.00"
            android:textColor="@color/color_acento"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCantidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 cartas en tu colección"
            android:textColor="@color/color_texto_secundario"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutLabelAcciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margen_medio"
        android:paddingEnd="@dimen/margen_pequeño"
        android:layout_marginTop="@dimen/margen_grande"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutValorTotal">

        <TextView
            android:id="@+id/tvLabelCartas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_cartas_agregadas"
            android:textColor="@color/color_texto_secundario"
            android:textSize="@dimen/texto_cuerpo" />

        <Button
            android:id="@+id/btnLimpiarPortfolio"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/portfolio_btn_limpiar"
            android:textColor="#EF5350"
            android:backgroundTint="@android:color/transparent"
            android:textSize="12sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margen_pequeño"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutLabelAcciones"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/contenedorPortfolio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/margen_medio"
            android:paddingEnd="@dimen/margen_medio"
            android:paddingTop="@dimen/margen_pequeño"
            android:paddingBottom="@dimen/margen_grande" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
