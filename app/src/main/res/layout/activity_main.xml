<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_app"
        android:textColor="@color/color_acento"
        android:textSize="@dimen/texto_titulo"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginTop="@dimen/margen_grande"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitulo_app"
        android:textColor="@color/color_texto_secundario"
        android:textSize="@dimen/texto_cuerpo"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

    <!-- Línea divisoria -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_borde"
        android:layout_marginTop="@dimen/margen_medio"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitulo" />

    <!-- Buscador -->
    <LinearLayout
        android:id="@+id/layoutBuscador"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        android:layout_marginTop="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <EditText
            android:id="@+id/etBuscar"
            android:layout_width="0dp"
            android:layout_height="@dimen/alto_boton"
            android:layout_weight="1"
            android:hint="@string/hint_buscar"
            android:textColor="@color/color_texto_primario"
            android:textColorHint="@color/color_texto_secundario"
            android:background="@drawable/fondo_input"
            android:paddingStart="@dimen/margen_medio"
            android:paddingEnd="@dimen/margen_medio"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch" />

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/alto_boton"
            android:layout_marginStart="@dimen/margen_pequeño"
            android:text="@string/btn_buscar"
            android:textColor="@color/color_fondo"
            android:backgroundTint="@color/color_acento" />

    </LinearLayout>

    <!-- ScrollView principal: contiene filtro de juegos + resultados -->
    <ScrollView
        android:id="@+id/scrollPrincipal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutBuscador"
        app:layout_constraintBottom_toTopOf="@id/navBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/margen_medio"
            android:paddingEnd="@dimen/margen_medio"
            android:paddingBottom="@dimen/margen_medio">

            <!-- Etiqueta filtro rápido -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_juegos"
                android:textColor="@color/color_texto_secundario"
                android:textSize="@dimen/texto_cuerpo"
                android:layout_marginBottom="@dimen/margen_pequeño" />

            <!-- Lista vertical de juegos (se llena desde Java) -->
            <LinearLayout
                android:id="@+id/contenedorJuegos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Etiqueta resultados -->
            <TextView
                android:id="@+id/tvResultados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_resultados"
                android:textColor="@color/color_texto_secundario"
                android:textSize="@dimen/texto_cuerpo"
                android:layout_marginTop="@dimen/margen_grande"
                android:layout_marginBottom="@dimen/margen_pequeño" />

            <!-- Resultados dinámicos -->
            <LinearLayout
                android:id="@+id/contenedorResultados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </ScrollView>

    <!-- Barra de navegación inferior -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/fondo_nav_bar"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        android:layout_marginBottom="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navBuscar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_buscar"
                android:tint="@color/color_acento" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_buscar"
                android:textColor="@color/color_acento"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPortfolio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_portfolio"
                android:tint="@color/color_texto_secundario" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_portfolio"
                android:textColor="@color/color_texto_secundario"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_perfil"
                android:tint="@color/color_texto_secundario" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_perfil"
                android:textColor="@color/color_texto_secundario"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
