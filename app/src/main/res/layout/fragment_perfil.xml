<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/perfilRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/margen_medio"
        android:paddingEnd="@dimen/margen_medio"
        android:paddingTop="@dimen/margen_grande"
        android:paddingBottom="@dimen/margen_pequeño"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/perfil_titulo"
            android:textColor="@color/color_acento"
            android:textSize="@dimen/texto_titulo"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitulo_app"
            android:textColor="@color/color_texto_secundario"
            android:textSize="@dimen/texto_cuerpo"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_borde"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <LinearLayout
        android:id="@+id/layoutUsuario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/fondo_carta"
        android:padding="@dimen/margen_medio"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        android:layout_marginTop="@dimen/margen_medio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_perfil"
            android:tint="@color/color_acento"
            android:background="@drawable/fondo_avatar"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/margen_medio">

            <TextView
                android:id="@+id/tvNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perfil_usuario"
                android:textColor="@color/color_texto_primario"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmailUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perfil_proximamente_login"
                android:textColor="@color/color_texto_secundario"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvLabelEstadisticas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/perfil_estadisticas"
        android:textColor="@color/color_texto_secundario"
        android:textSize="@dimen/texto_cuerpo"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginTop="@dimen/margen_grande"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutUsuario" />

    <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/margen_medio"
        android:layout_marginEnd="@dimen/margen_medio"
        android:layout_marginTop="@dimen/margen_pequeño"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelEstadisticas">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/margen_pequeño">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/fondo_carta"
                android:padding="@dimen/margen_medio"
                android:layout_marginEnd="@dimen/margen_pequeño">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perfil_total_cartas"
                    android:textColor="@color/color_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvStatCartas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/color_acento"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/fondo_carta"
                android:padding="@dimen/margen_medio"
                android:layout_marginStart="@dimen/margen_pequeño">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/portfolio_valor_total"
                    android:textColor="@color/color_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvStatValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0.00"
                    android:textColor="@color/color_acento"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/fondo_carta"
                android:padding="@dimen/margen_medio"
                android:layout_marginEnd="@dimen/margen_pequeño">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perfil_juegos"
                    android:textColor="@color/color_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvStatJuegos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/color_acento"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/fondo_carta"
                android:padding="@dimen/margen_medio"
                android:layout_marginStart="@dimen/margen_pequeño">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perfil_carta_valiosa"
                    android:textColor="@color/color_texto_secundario"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvStatMasValiosa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/color_acento"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/perfil_cerrar_sesion"
        android:textColor="#EF5350"
        android:backgroundTint="@android:color/transparent"
        android:layout_marginTop="@dimen/margen_grande"
        app:layout_constraintTop_toBottomOf="@id/layoutStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
